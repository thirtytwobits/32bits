---
/**
 * Tri-state theme switch (light / system / dark) — DESIGN R10.
 *
 * Stores choice in localStorage under `theme-32bits`. When set to
 * "system" (default), no `data-theme` attribute is set on <html>; CSS
 * falls back to `prefers-color-scheme`.
 *
 * Iconography only (no text labels) per R10. Tiny SVGs inline so we
 * don't add an icon-font dependency.
 */
---

<span class="theme-switch" role="group" aria-label="Color theme">
  <button data-theme-button="light" aria-label="Light theme" aria-pressed="false">
    <svg
      viewBox="0 0 16 16"
      width="14"
      height="14"
      fill="none"
      stroke="currentColor"
      stroke-width="1.4"
      stroke-linecap="round"
    >
      <circle cx="8" cy="8" r="3"></circle>
      <line x1="8" y1="1.5" x2="8" y2="3"></line>
      <line x1="8" y1="13" x2="8" y2="14.5"></line>
      <line x1="1.5" y1="8" x2="3" y2="8"></line>
      <line x1="13" y1="8" x2="14.5" y2="8"></line>
      <line x1="3.4" y1="3.4" x2="4.4" y2="4.4"></line>
      <line x1="11.6" y1="11.6" x2="12.6" y2="12.6"></line>
      <line x1="3.4" y1="12.6" x2="4.4" y2="11.6"></line>
      <line x1="11.6" y1="4.4" x2="12.6" y2="3.4"></line>
    </svg>
  </button>
  <button data-theme-button="system" aria-label="System theme" aria-pressed="true">
    <svg
      viewBox="0 0 16 16"
      width="14"
      height="14"
      fill="none"
      stroke="currentColor"
      stroke-width="1.4"
      stroke-linecap="round"
    >
      <rect x="2" y="3" width="12" height="8" rx="1"></rect>
      <line x1="6" y1="13.5" x2="10" y2="13.5"></line>
      <line x1="8" y1="11" x2="8" y2="13.5"></line>
    </svg>
  </button>
  <button data-theme-button="dark" aria-label="Dark theme" aria-pressed="false">
    <svg
      viewBox="0 0 16 16"
      width="14"
      height="14"
      fill="none"
      stroke="currentColor"
      stroke-width="1.4"
      stroke-linecap="round"
      stroke-linejoin="round"
    >
      <path d="M13.5 9.5a5 5 0 0 1-7-7 5.5 5.5 0 1 0 7 7z"></path>
    </svg>
  </button>
</span>

<style>
  .theme-switch {
    display: inline-flex;
    gap: 0.125rem;
  }
  .theme-switch button {
    background: none;
    border: none;
    color: inherit;
    cursor: pointer;
    padding: 0.25rem;
    opacity: 0.45;
    line-height: 0;
    transition: opacity 120ms ease;
  }
  .theme-switch button[aria-pressed='true'] {
    opacity: 1;
  }
  .theme-switch button:hover {
    opacity: 0.85;
  }
</style>

<script>
  const root = document.documentElement;
  const buttons = document.querySelectorAll<HTMLButtonElement>('[data-theme-button]');
  const apply = (mode: string) => {
    if (mode === 'light' || mode === 'dark') root.dataset.theme = mode;
    else root.removeAttribute('data-theme');
    buttons.forEach((b) => b.setAttribute('aria-pressed', String(b.dataset.themeButton === mode)));
    try {
      localStorage.setItem('theme-32bits', mode);
    } catch {
      /* storage may be unavailable (private mode); silently no-op */
    }
  };
  let stored: string | null = null;
  try {
    stored = localStorage.getItem('theme-32bits');
  } catch {
    /* same as above */
  }
  apply(stored ?? 'system');
  buttons.forEach((b) => b.addEventListener('click', () => apply(b.dataset.themeButton!)));
</script>
