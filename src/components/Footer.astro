---
/**
 * Footer — full-width band at the very end of every page.
 *
 * On Home: tagline (left) + social icons (right).
 * On project pages: NO tagline, social icons only (DESIGN R10 footer rules).
 *
 * No copyright, no year, no nav. R8 minimal chrome.
 */
interface Props {
  showTagline?: boolean;
  tagline?: string;
}

const { showTagline = false, tagline = '// I like to make things.' } = Astro.props;

const links = {
  github: 'https://github.com/thirtytwobits',
  linkedin: 'https://www.linkedin.com/in/scott-dixon-4aa1a51/',
};
---

<footer class="site-footer">
  <span class="tagline">
    {showTagline ? tagline : ''}
  </span>
  <span class="icons">
    <a href={links.github} rel="me noopener" target="_blank" aria-label="GitHub">
      <svg viewBox="0 0 16 16" width="16" height="16" fill="currentColor" aria-hidden="true">
        <path
          d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27s1.36.09 2 .27c1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.013 8.013 0 0 0 16 8c0-4.42-3.58-8-8-8z"
        ></path>
      </svg>
    </a>
    <a href={links.linkedin} rel="me noopener" target="_blank" aria-label="LinkedIn">
      <svg viewBox="0 0 16 16" width="16" height="16" fill="currentColor" aria-hidden="true">
        <path
          d="M13.6 0H2.4A2.4 2.4 0 0 0 0 2.4v11.2A2.4 2.4 0 0 0 2.4 16h11.2a2.4 2.4 0 0 0 2.4-2.4V2.4A2.4 2.4 0 0 0 13.6 0zM4.86 13.71H2.5V6.05h2.36v7.66zM3.68 5.04a1.37 1.37 0 1 1 0-2.74 1.37 1.37 0 0 1 0 2.74zm10.03 8.67h-2.36V9.74c0-1 0-2.28-1.39-2.28s-1.61 1.09-1.61 2.21v4.04H6V6.05h2.27v1.05h.03c.32-.6 1.1-1.23 2.27-1.23 2.43 0 2.88 1.6 2.88 3.68v4.16z"
        ></path>
      </svg>
    </a>
  </span>
</footer>

<style>
  .site-footer {
    background: var(--bg-deep);
    padding: 2rem 3rem;
    font-family: var(--font-mono);
    font-size: 0.8125rem;
    color: var(--muted);
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 2rem;
  }
  @media (max-width: 720px) {
    .site-footer {
      padding: 1.5rem;
    }
  }
  .tagline {
    /* Always present in DOM (so flex spacing is consistent) but rendered
       empty on project pages. */
    flex: 1;
  }
  .icons {
    display: flex;
    gap: 1rem;
  }
  .icons a {
    color: inherit;
    text-decoration: none;
    line-height: 0;
    opacity: 0.65;
    transition: opacity 120ms ease;
  }
  .icons a:hover {
    opacity: 1;
    color: var(--accent);
  }
</style>
