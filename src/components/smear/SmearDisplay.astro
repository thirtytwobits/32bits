---
/**
 * SmearDisplay — full-width display heading section, no image.
 *
 * Used to break up image groupings with a large typographic moment.
 * Display type at clamp(3rem, 9vw, 7.5rem). Use sparingly — one or two
 * per project.
 *
 * Wrap accented words in `<em>` to color them with the brand accent.
 *
 * The slot is the heading content. `label` is the optional monospace
 * micro-label above the heading (e.g., "// the question").
 */
interface Props {
  label?: string;
}

const { label } = Astro.props;
---

<section class="smear-display">
  {label && <p class="label">{label}</p>}
  <div class="head"><slot /></div>
</section>

<style>
  .smear-display {
    padding: 10rem 4rem 8rem;
    background: var(--bg);
  }
  @media (max-width: 720px) {
    .smear-display {
      padding: 5rem 1.5rem 4rem;
    }
  }
  .label {
    font-family: var(--font-mono);
    font-size: 0.8125rem;
    color: var(--muted);
    margin: 0 0 1.5rem;
  }
  .head :global(*) {
    font-family: var(--font-display);
    font-size: clamp(3rem, 9vw, 7.5rem);
    font-weight: 500;
    letter-spacing: -0.045em;
    line-height: 0.95;
    margin: 0;
    max-width: 18ch;
    color: var(--fg);
  }
  .head :global(em) {
    font-style: normal;
    color: var(--accent);
  }
  .head :global(code) {
    font-family: var(--font-mono);
    font-size: 0.85em;
    color: var(--accent);
  }
</style>
