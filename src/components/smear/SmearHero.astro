---
/**
 * SmearHero — first composition on a Smear project page.
 *
 * The image bleeds in from the right and extends ~10vw past the right
 * edge of the viewport (a deliberate breakout). The title is pinned to
 * the lower-left and uses mix-blend-mode: difference for legibility
 * over whatever the image happens to be.
 *
 * On mobile the bleed flattens — image stacks above the title at
 * normal width.
 */
import { url } from '@lib/url';

interface Props {
  title: string;
  image: string;
  alt: string;
  meta?: string;
}

const { title, image, alt, meta } = Astro.props;
const src = url(image);
---

<header class="smear-hero">
  <img src={src} alt={alt} loading="eager" fetchpriority="high" decoding="async" />
  <div class="text">
    {meta && <p class="meta">{meta}</p>}
    <h1 set:html={title} />
  </div>
</header>

<style>
  .smear-hero {
    position: relative;
    min-height: 90vh;
    overflow: hidden;
  }
  .smear-hero img {
    position: absolute;
    top: 0;
    right: -10vw;
    width: 80vw;
    height: 100%;
    object-fit: cover;
    object-position: center;
    display: block;
  }
  .text {
    position: absolute;
    bottom: 4rem;
    left: 4rem;
    z-index: 2;
    max-width: min(60ch, 50vw);
  }
  @media (max-width: 720px) {
    .smear-hero {
      min-height: 0;
      display: flex;
      flex-direction: column;
    }
    .smear-hero img {
      position: static;
      width: 100vw;
      height: 60vh;
    }
    .text {
      position: static;
      padding: 2rem 1.5rem;
      max-width: none;
    }
  }
  .meta {
    font-family: var(--font-mono);
    font-size: 0.8125rem;
    color: var(--muted);
    margin: 0 0 0.75rem;
  }
  h1 {
    font-family: var(--font-display);
    font-size: clamp(3.5rem, 11vw, 9rem);
    font-weight: 600;
    letter-spacing: -0.05em;
    line-height: 0.88;
    margin: 0;
    color: var(--bg);
    mix-blend-mode: difference;
  }
  @media (max-width: 720px) {
    h1 {
      mix-blend-mode: normal;
      color: var(--fg);
    }
  }
</style>
