---
/**
 * ScrollToTop — thin full-width band placed above the footer.
 *
 * After scrolling through a long project page, the reader is far from
 * the brand mark in the top-left. This is the cheap way back. A
 * `<button>` (not an `<a>`) because we're triggering an action on the
 * current page, not navigating elsewhere.
 *
 * Smooth scroll honors `prefers-reduced-motion` — falls back to an
 * instant jump for users who request reduced motion.
 */
---

<button class="scroll-to-top" type="button" aria-label="Scroll to top of page">
  <svg
    viewBox="0 0 16 16"
    width="13"
    height="13"
    fill="none"
    stroke="currentColor"
    stroke-width="1.5"
    stroke-linecap="round"
    stroke-linejoin="round"
    aria-hidden="true"
  >
    <path d="M8 13 V3 M3.5 7.5 L8 3 L12.5 7.5"></path>
  </svg>
  <span>to the top</span>
</button>

<style>
  .scroll-to-top {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.625rem;
    width: 100%;
    padding: 1.5rem;
    background: var(--bg);
    border: none;
    border-top: 1px solid var(--rule);
    font-family: var(--font-mono);
    font-size: 0.8125rem;
    color: var(--muted);
    cursor: pointer;
    transition: color 120ms ease;
  }
  .scroll-to-top:hover {
    color: var(--accent);
  }
  .scroll-to-top svg {
    display: block;
  }
</style>

<script>
  document.querySelectorAll<HTMLButtonElement>('button.scroll-to-top').forEach((b) => {
    b.addEventListener('click', () => {
      const reduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
      window.scrollTo({ top: 0, behavior: reduce ? 'auto' : 'smooth' });
    });
  });
</script>
