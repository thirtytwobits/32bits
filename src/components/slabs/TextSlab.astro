---
/**
 * TextSlab — solid full-screen panel for body or display text.
 *
 * Used as the child of <Scene>. Has a single optional monospace label
 * (e.g., "// premise") and the rest is body or display content via slot.
 *
 * The slot content can be plain MDX prose or specific elements styled
 * by this component's CSS (`.display`, `.body`).
 */
interface Props {
  label?: string;
  /** Vertical alignment within the slab. Default 'center'. */
  align?: 'top' | 'center' | 'bottom';
}

const { label, align = 'center' } = Astro.props;
const justify = align === 'top' ? 'flex-start' : align === 'bottom' ? 'flex-end' : 'center';
---

<div class="slab" style={`justify-content: ${justify}`}>
  {label && <p class="label">{label}</p>}
  <div class="content"><slot /></div>
</div>

<style>
  .slab {
    width: 100%;
    height: 100%;
    background: var(--bg);
    display: flex;
    flex-direction: column;
    padding: 4rem;
    gap: 1.25rem;
  }
  @media (max-width: 720px) {
    .slab {
      padding: 4rem 1.5rem;
    }
  }
  .label {
    font-family: var(--font-mono);
    font-size: 0.875rem;
    color: var(--muted);
    margin: 0;
  }
  /* Default styling for the slot content. Authors can override via
     custom classes in MDX. */
  .content :global(p) {
    margin: 0 0 1.25rem;
  }
  .content :global(p:last-child) {
    margin-bottom: 0;
  }
  .content :global(.display) {
    font-family: var(--font-display);
    font-size: clamp(2.5rem, 6vw, 5rem);
    font-weight: 500;
    letter-spacing: -0.04em;
    line-height: 1.05;
    margin: 0;
    max-width: 22ch;
  }
  .content :global(.body) {
    font-family: var(--font-body);
    font-size: clamp(1.125rem, 1.6vw, 1.5rem);
    line-height: 1.5;
    max-width: 50ch;
    margin: 0;
  }
  .content :global(em) {
    font-style: normal;
    color: var(--accent);
  }
  .content :global(code) {
    font-family: var(--font-mono);
    font-size: 0.85em;
    color: var(--accent);
  }
</style>
