---
/**
 * Home — DESIGN R10 / Level 0.
 *
 * A vertical reel of full-bleed project tiles in `order` ascending.
 * No centered content rails. The brand mark sits in the top-left as
 * an identity element (not a link, since this is Home). The footer
 * shows the tagline (Home only).
 *
 * Hidden / draft projects are excluded from the overview but still
 * reachable by direct URL (hidden) or not built at all (draft).
 */
import { getCollection } from 'astro:content';
import BaseLayout from '@layouts/BaseLayout.astro';
import BrandMark from '@components/BrandMark.astro';
import ThemeSwitch from '@components/ThemeSwitch.astro';
import Footer from '@components/Footer.astro';
import ScrollToTop from '@components/ScrollToTop.astro';
import HomeTile from '@components/HomeTile.astro';

const projects = (await getCollection('projects', ({ data }) => !data.draft && !data.hidden)).sort(
  (a, b) => a.data.order - b.data.order,
);
---

<BaseLayout title="thirty-two">
  <div class="topbar">
    <BrandMark size={32} asHomeLink={false} forceInvertOnDark={true} alt="" />
    <ThemeSwitch />
  </div>

  <main>
    {projects.map((p, i) => <HomeTile project={p} loading={i === 0 ? 'eager' : 'lazy'} />)}
  </main>

  <ScrollToTop />
  <Footer showTagline={true} />
</BaseLayout>

<style>
  .topbar {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 1rem 1.5rem;
    z-index: 100;
    /* Same blend-mode trick as ProjectLayout — keeps the chrome
       readable over any tile image regardless of palette. */
    mix-blend-mode: difference;
    color: #f5f0e8;
    font-family: var(--font-mono);
    font-size: 0.75rem;
  }
  main {
    /* The reel of tiles is the page's primary content. No padding,
       no max-width — the tiles themselves are 100vw. */
    display: block;
  }
</style>
