---
/**
 * Layout 01 — "Slabs"
 *
 * Philosophy: each section is exactly one viewport tall (100vh) with
 * scroll-snap. Like Apple's product pages or a deck of cards. Each
 * image is a full-screen statement; you commit to one, then the next.
 * Cinematic, controlled, deliberately paced.
 */
import '@fontsource-variable/space-grotesk';
import '@fontsource/ibm-plex-sans/400.css';
import '@fontsource/ibm-plex-sans/500.css';
import '@fontsource/ibm-plex-sans/600.css';
import '@fontsource-variable/jetbrains-mono';
import '@styles/design-system.css';

const SQ = 'https://images.squarespace-cdn.com/content/v1/593de2cd3e00be288f77c692';
const img = {
  hero: `${SQ}/1742871116774-S43STVJ3XHT9S0OXIMEM/dangerlab.png?format=2500w`,
  lab: `${SQ}/95b8ab0e-f11d-4c4a-ac8f-0f837379ad49/IMG_0824.JPG?format=2500w`,
  cad: `${SQ}/2cc13804-6bb5-4a03-ba10-7ae86c56b520/Stackup_FFF_MKII_2025-Apr-13_08-03-47PM-000_CustomizedView20432568841.png?format=2500w`,
  prusa: `${SQ}/3d3216d4-0256-4eb7-b364-f8f835eb9df5/began-using-a-webapp-shortcut-for-prusaconnect-thought-it-v0-8608sohp7ujc1.png?format=2500w`,
  detail: `${SQ}/1742876946171-DYQYWL1JM8VZH37WLHKQ/IMG_4147.png?format=2500w`,
};
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Layout 01 — Slabs</title>
    <meta name="robots" content="noindex" />
    <style>
      html,
      body {
        scroll-snap-type: y proximity;
      }

      .topbar {
        position: fixed;
        top: 0;
        left: 0;
        right: 0;
        display: flex;
        align-items: center;
        justify-content: space-between;
        padding: 1rem 1.5rem;
        z-index: 50;
        font-family: var(--font-mono);
        font-size: 0.75rem;
        mix-blend-mode: difference;
        color: #f5f0e8;
      }
      .topbar a {
        text-decoration: none;
      }
      /* See option-1: difference-blend visibility override. */
      .topbar .rock-fixed img {
        filter: invert(1);
      }

      /* Every section is exactly one viewport. */
      .slab {
        height: 100vh;
        width: 100vw;
        scroll-snap-align: start;
        position: relative;
        overflow: hidden;
      }

      /* Title slab — text-only, deliberately quiet so first image hits hard. */
      .slab.title {
        display: flex;
        flex-direction: column;
        justify-content: flex-end;
        padding: 4rem;
        background: var(--bg);
      }
      @media (max-width: 720px) {
        .slab.title {
          padding: 2rem 1.5rem;
        }
      }
      .slab.title .meta {
        font-family: var(--font-mono);
        font-size: 0.875rem;
        color: var(--muted);
        margin: 0 0 1rem;
      }
      .slab.title h1 {
        font-family: var(--font-display);
        font-size: clamp(4rem, 14vw, 12rem);
        font-weight: 600;
        letter-spacing: -0.05em;
        line-height: 0.88;
        margin: 0;
      }
      .slab.title .summary {
        font-family: var(--font-body);
        font-size: clamp(1rem, 1.4vw, 1.25rem);
        color: var(--muted);
        margin: 1.5rem 0 0;
        max-width: 50ch;
      }
      .slab.title .scroll-hint {
        position: absolute;
        bottom: 2rem;
        right: 2rem;
        font-family: var(--font-mono);
        font-size: 0.75rem;
        color: var(--muted);
      }

      /* Image slab — image fills the slab via cover, may crop. */
      .slab.image img {
        width: 100%;
        height: 100%;
        object-fit: cover;
        display: block;
      }

      /* Text slab — single statement, no image. */
      .slab.text {
        display: flex;
        align-items: center;
        padding: 4rem;
        background: var(--bg-deep);
      }
      @media (max-width: 720px) {
        .slab.text {
          padding: 2rem 1.5rem;
        }
      }
      .slab.text p {
        font-family: var(--font-display);
        font-size: clamp(2rem, 5vw, 4rem);
        font-weight: 500;
        letter-spacing: -0.03em;
        line-height: 1.05;
        max-width: 22ch;
        margin: 0;
      }
      .slab.text p code {
        font-family: var(--font-mono);
        font-size: 0.85em;
        color: var(--accent);
      }
      .slab.text .label {
        position: absolute;
        top: 4rem;
        left: 4rem;
        font-family: var(--font-mono);
        font-size: 0.8125rem;
        color: var(--muted);
      }
      @media (max-width: 720px) {
        .slab.text .label {
          top: 1.5rem;
          left: 1.5rem;
        }
      }

      /* Split slab — image one half, text the other. */
      .slab.split {
        display: grid;
        grid-template-columns: 1fr 1fr;
      }
      @media (max-width: 720px) {
        .slab.split {
          grid-template-rows: 1fr 1fr;
          grid-template-columns: 1fr;
        }
      }
      .slab.split .img-half {
        position: relative;
      }
      .slab.split .img-half img {
        width: 100%;
        height: 100%;
        object-fit: cover;
      }
      .slab.split .text-half {
        background: var(--bg);
        padding: 3rem;
        display: flex;
        align-items: center;
      }
      .slab.split .text-half p {
        font-family: var(--font-body);
        font-size: clamp(1rem, 1.3vw, 1.1875rem);
        line-height: 1.55;
        margin: 0;
      }
      .slab.split .text-half .caption {
        font-family: var(--font-mono);
        font-size: 0.75rem;
        color: var(--muted);
        margin: 0 0 0.75rem;
      }

      /* Final slab combines prev/next + footer. */
      .slab.end {
        display: flex;
        flex-direction: column;
        background: var(--bg);
      }
      .end .prevnext {
        flex: 1;
        display: grid;
        grid-template-columns: 1fr 1fr;
      }
      @media (max-width: 720px) {
        .end .prevnext {
          grid-template-columns: 1fr;
        }
      }
      .end .prevnext a {
        padding: 4rem 3rem;
        text-decoration: none;
        color: var(--fg);
        font-family: var(--font-display);
        font-size: clamp(1.5rem, 3vw, 2.25rem);
        font-weight: 500;
        letter-spacing: -0.03em;
        display: flex;
        flex-direction: column;
        justify-content: center;
      }
      .end .prevnext a:hover {
        color: var(--accent);
      }
      .end .prevnext a + a {
        border-left: 1px solid var(--rule);
        text-align: right;
        align-items: flex-end;
      }
      @media (max-width: 720px) {
        .end .prevnext a + a {
          border-left: none;
          border-top: 1px solid var(--rule);
        }
      }
      .end .prevnext .label {
        font-family: var(--font-mono);
        font-size: 0.75rem;
        font-weight: 400;
        color: var(--muted);
        margin-bottom: 0.5rem;
      }
      .end .footer {
        background: var(--bg-deep);
        padding: 2rem 3rem;
        font-family: var(--font-mono);
        font-size: 0.8125rem;
        color: var(--muted);
        display: flex;
        justify-content: space-between;
        align-items: center;
      }
      .end .footer .icons {
        display: flex;
        gap: 1.25rem;
      }

      /* Notes — one extra slab past the snap chain */
      .notes {
        padding: 6rem 3rem;
        background: var(--bg);
        border-top: 1px solid var(--rule);
      }
      .notes h3 {
        font-family: var(--font-display);
        font-size: 1.5rem;
        font-weight: 600;
        margin: 2rem 0 0.75rem;
      }
      .notes p,
      .notes li {
        font-family: var(--font-body);
        font-size: 0.9375rem;
        line-height: 1.65;
        color: var(--muted);
        max-width: 70ch;
      }
      .notes ul {
        padding-left: 1.25rem;
      }
      .notes strong {
        color: var(--fg);
        font-weight: 600;
      }
      .notes .label {
        font-family: var(--font-mono);
        font-size: 0.8125rem;
        color: var(--muted);
        margin: 0;
      }
      .notes code {
        font-family: var(--font-mono);
        font-size: 0.875em;
        color: var(--accent);
      }
    </style>
  </head>
  <body>
    <div class="topbar">
      <a href="/">
        <span class="brand-mark rock-fixed"><img src="/brand-mark.png" alt="Home" /></span>
      </a>
      <span class="theme-switch">
        <button data-theme-button="light" aria-pressed="false">light</button>
        <button data-theme-button="system" aria-pressed="true">system</button>
        <button data-theme-button="dark" aria-pressed="false">dark</button>
      </span>
    </div>

    <!-- Title slab -->
    <section class="slab title">
      <p class="meta">/projects/danger-lab · 01 of 25</p>
      <h1>Danger<br />Lab</h1>
      <p class="summary">
        A common module for mounting small hardware. The unglamorous fix to the chaos that erases a
        Sunday.
      </p>
      <p class="scroll-hint">scroll ↓</p>
    </section>

    <!-- Image-only slab -->
    <section class="slab image">
      <img src={img.lab} alt="A disorganized lab bench covered in devkits" />
    </section>

    <!-- Text-only statement slab -->
    <section class="slab text">
      <span class="label">// premise</span>
      <p>
        How much of your debug time gets spent on a <code>loose wire</code> instead of the bug you meant
        to fix?
      </p>
    </section>

    <!-- Image-only slab -->
    <section class="slab image">
      <img src={img.cad} alt="CAD render of the Danger Lab module stack" />
    </section>

    <!-- Split slab: image half + text half -->
    <section class="slab split">
      <div class="img-half">
        <img src={img.prusa} alt="Prusa Connect on iOS" />
      </div>
      <div class="text-half">
        <div>
          <p class="caption">// fig. 03 — prusa connect web shortcut</p>
          <p>
            The base is a <code>6 mm</code> expanded-PVC sheet, <code>30.5 cm</code> square, with five
            <code>4 mm</code> holes. PVC was chosen for the balance between rigidity and workability,
            and because it doesn't conduct.
          </p>
        </div>
      </div>
    </section>

    <!-- Final image slab -->
    <section class="slab image">
      <img src={img.hero} alt="Hero render of the assembled module" />
    </section>

    <!-- End slab — prev/next + footer combined -->
    <section class="slab end">
      <nav class="prevnext" aria-label="Adjacent projects">
        <a href="#">
          <span class="label">← prev</span>
          Stacking Stones
        </a>
        <a href="#">
          <span class="label">next →</span>
          Dragon Head
        </a>
      </nav>
      <footer class="footer">
        <span>// I like to make things.</span>
        <span class="icons">
          <span>github</span>
          <span>linkedin</span>
        </span>
      </footer>
    </section>

    <aside class="notes">
      <p class="label">[layout · 01 · slabs]</p>
      <h3>What's intentional</h3>
      <ul>
        <li>
          <strong>Each section is exactly 100vh.</strong> Image slabs, text slabs, split slabs, and the
          final prev/next slab — all the same canvas size. Reads as a deck.
        </li>
        <li>
          <strong>CSS scroll-snap (proximity)</strong> — the page nudges you to the next slab when you
          stop scrolling, but doesn't fight you mid-scroll. Snaps off entirely on
          <code>prefers-reduced-motion</code>.
        </li>
        <li>
          <strong>Images use <code>object-fit: cover</code></strong> so each one fills the slab. Edges
          crop. Trade-off vs the Stream layout: more dramatic, less faithful to original aspect ratio.
        </li>
        <li>
          <strong>Text slabs are loud.</strong> Display type at 4rem+ size, single statement per slab.
          The text earns its full screen.
        </li>
      </ul>
      <h3>What's deliberately not used</h3>
      <ul>
        <li>No mid-slab scrolling. Each thought lives or dies on one screen.</li>
        <li>
          No "snap mandatory" — that's hostile on touchpads and accessibility. Proximity is the
          right level of nudge.
        </li>
        <li>No carousels. Forward motion is always vertical scroll.</li>
      </ul>
    </aside>

    <script>
      const root = document.documentElement;
      const buttons = document.querySelectorAll<HTMLButtonElement>('[data-theme-button]');
      const stored = localStorage.getItem('theme-32bits');
      const apply = (mode: string) => {
        if (mode === 'light' || mode === 'dark') root.dataset.theme = mode;
        else root.removeAttribute('data-theme');
        buttons.forEach((b) =>
          b.setAttribute('aria-pressed', String(b.dataset.themeButton === mode)),
        );
        localStorage.setItem('theme-32bits', mode);
      };
      apply(stored ?? 'system');
      buttons.forEach((b) => b.addEventListener('click', () => apply(b.dataset.themeButton!)));
    </script>
  </body>
</html>
