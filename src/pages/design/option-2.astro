---
/**
 * Layout 02 — "Slabs Reveal"
 *
 * Two patterns, both with a STATIC image (sticky, pinned at viewport
 * top) and a SOLID slab. Pattern is determined by the slab's relative
 * position to the image:
 *
 *   1. COVER   — image visible first; slab arrives FROM BELOW and rises
 *                up to cover the image. Ends with the slab covering.
 *
 *   2. REVEAL  — slab is positioned ON TOP of the static image at the
 *                start (via `margin-top: -100vh` on the slab). The
 *                image is sticky-pinned underneath — it does NOT scroll
 *                in from below. As you scroll, the slab departs upward
 *                off the viewport, exposing the image that was always
 *                there. Image then dwells.
 *
 * Both patterns are pure CSS using `position: sticky` + z-index.
 * What changes between them: in COVER the slab is in flow AFTER the
 * image (so it starts below the fold and rises). In REVEAL the slab
 * is pulled UP onto the image with a negative margin, so it starts
 * already covering — the image was static behind it the whole time.
 */
import '@fontsource-variable/space-grotesk';
import '@fontsource/ibm-plex-sans/400.css';
import '@fontsource/ibm-plex-sans/500.css';
import '@fontsource/ibm-plex-sans/600.css';
import '@fontsource-variable/jetbrains-mono';
import '@styles/design-system.css';

const SQ = 'https://images.squarespace-cdn.com/content/v1/593de2cd3e00be288f77c692';
const img = {
  hero: `${SQ}/1742871116774-S43STVJ3XHT9S0OXIMEM/dangerlab.png?format=2500w`,
  lab: `${SQ}/95b8ab0e-f11d-4c4a-ac8f-0f837379ad49/IMG_0824.JPG?format=2500w`,
  cad: `${SQ}/2cc13804-6bb5-4a03-ba10-7ae86c56b520/Stackup_FFF_MKII_2025-Apr-13_08-03-47PM-000_CustomizedView20432568841.png?format=2500w`,
  prusa: `${SQ}/3d3216d4-0256-4eb7-b364-f8f835eb9df5/began-using-a-webapp-shortcut-for-prusaconnect-thought-it-v0-8608sohp7ujc1.png?format=2500w`,
  detail: `${SQ}/1742876946171-DYQYWL1JM8VZH37WLHKQ/IMG_4147.png?format=2500w`,
};
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Layout 02 — Slabs Reveal</title>
    <meta name="robots" content="noindex" />
    <style>
      .topbar {
        position: fixed;
        top: 0;
        left: 0;
        right: 0;
        display: flex;
        align-items: center;
        justify-content: space-between;
        padding: 1rem 1.5rem;
        z-index: 100;
        font-family: var(--font-mono);
        font-size: 0.75rem;
        mix-blend-mode: difference;
        color: #f5f0e8;
      }
      .topbar a {
        text-decoration: none;
      }
      .topbar .rock-fixed img {
        filter: invert(1);
      }

      /* Scene establishes a positioning context for the sticky image. */
      .scene {
        position: relative;
      }

      /* Sticky image — pinned at viewport top while its parent scene is
         in view. The image is STATIC visually: it does not scroll in
         from below; it does not scroll out the top until its scene's
         dwell room is exhausted. z-index: 1 puts it under the slab. */
      .scene-image {
        position: sticky;
        top: 0;
        width: 100vw;
        height: 100vh;
        z-index: 1;
        background-size: cover;
        background-position: center;
      }

      /* Solid slab — opaque var(--bg). z-index: 2 covers the sticky
         image when both occupy the same viewport area. */
      .text-slab {
        position: relative;
        z-index: 2;
        width: 100vw;
        height: 100vh;
        display: flex;
        flex-direction: column;
        justify-content: center;
        padding: 0 4rem;
        background: var(--bg);
      }
      @media (max-width: 720px) {
        .text-slab {
          padding: 0 1.5rem;
        }
      }
      .text-slab .label {
        font-family: var(--font-mono);
        font-size: 0.875rem;
        color: var(--muted);
        margin: 0 0 1.25rem;
      }
      .text-slab .display {
        font-family: var(--font-display);
        font-size: clamp(2.5rem, 6vw, 5rem);
        font-weight: 500;
        letter-spacing: -0.04em;
        line-height: 1.05;
        margin: 0;
        max-width: 22ch;
      }
      .text-slab .display em {
        font-style: normal;
        color: var(--accent);
      }
      .text-slab .display code {
        font-family: var(--font-mono);
        font-size: 0.85em;
        color: var(--accent);
      }
      .text-slab.title .meta {
        font-family: var(--font-mono);
        font-size: 0.875rem;
        color: var(--muted);
        margin: 0 0 1rem;
      }
      .text-slab.title h1 {
        font-family: var(--font-display);
        font-size: clamp(4rem, 13vw, 11rem);
        font-weight: 600;
        letter-spacing: -0.05em;
        line-height: 0.88;
        margin: 0;
      }

      /* === REVEAL pattern ===
         Slab is positioned ON TOP of the static image at scroll-0 via
         negative margin. Image is sticky-pinned behind. As you scroll,
         the slab departs upward — the image was always there, and is
         now exposed. */
      .scene.reveal .text-slab {
        margin-top: -100vh;
      }
      /* `.dwell` extends the scene below the slab, giving the sticky
         image room to stay pinned after the slab has departed. Without
         this, the image would unstick the moment the slab cleared. */
      .dwell {
        height: 200vh;
        position: relative;
        z-index: 0;
      }

      /* Plain full-bleed image (no scene wrapper, no sticky behavior) —
         used between scenes for rhythm. */
      .bleed {
        display: block;
        width: 100vw;
        height: auto;
      }

      /* Prev/next */
      .prevnext {
        position: relative;
        z-index: 3;
        background: var(--bg);
        display: grid;
        grid-template-columns: 1fr 1fr;
        min-height: 60vh;
      }
      @media (max-width: 720px) {
        .prevnext {
          grid-template-columns: 1fr;
        }
      }
      .prevnext a {
        padding: 4rem 3rem;
        text-decoration: none;
        color: var(--fg);
        font-family: var(--font-display);
        font-size: clamp(1.5rem, 3vw, 2.25rem);
        font-weight: 500;
        letter-spacing: -0.03em;
        display: flex;
        flex-direction: column;
        justify-content: center;
      }
      .prevnext a:hover {
        color: var(--accent);
      }
      .prevnext a + a {
        border-left: 1px solid var(--rule);
        text-align: right;
        align-items: flex-end;
      }
      @media (max-width: 720px) {
        .prevnext a + a {
          border-left: none;
          border-top: 1px solid var(--rule);
        }
      }
      .prevnext .label {
        font-family: var(--font-mono);
        font-size: 0.75rem;
        font-weight: 400;
        color: var(--muted);
        margin-bottom: 0.5rem;
      }

      .footer {
        position: relative;
        z-index: 3;
        background: var(--bg-deep);
        padding: 2rem 3rem;
        font-family: var(--font-mono);
        font-size: 0.8125rem;
        color: var(--muted);
        display: flex;
        justify-content: space-between;
        align-items: center;
      }
      @media (max-width: 720px) {
        .footer {
          padding: 1.5rem;
        }
      }
      .footer .icons {
        display: flex;
        gap: 1.25rem;
      }

      .notes {
        position: relative;
        z-index: 3;
        padding: 6rem 3rem;
        background: var(--bg);
        border-top: 1px solid var(--rule);
      }
      @media (max-width: 720px) {
        .notes {
          padding: 4rem 1.5rem;
        }
      }
      .notes h3 {
        font-family: var(--font-display);
        font-size: 1.5rem;
        font-weight: 600;
        margin: 2rem 0 0.75rem;
      }
      .notes p,
      .notes li {
        font-family: var(--font-body);
        font-size: 0.9375rem;
        line-height: 1.65;
        color: var(--muted);
        max-width: 70ch;
      }
      .notes ul {
        padding-left: 1.25rem;
      }
      .notes strong {
        color: var(--fg);
        font-weight: 600;
      }
      .notes .label {
        font-family: var(--font-mono);
        font-size: 0.8125rem;
        color: var(--muted);
        margin: 0;
      }
      .notes code {
        font-family: var(--font-mono);
        font-size: 0.875em;
        color: var(--accent);
      }
      .pattern-tag {
        display: inline-block;
        font-family: var(--font-mono);
        font-size: 0.6875rem;
        text-transform: uppercase;
        letter-spacing: 0.04em;
        color: var(--accent);
        border: 1px solid var(--accent);
        padding: 0.125rem 0.5rem;
        border-radius: 999px;
        margin-right: 0.5rem;
      }
    </style>
  </head>
  <body>
    <div class="topbar">
      <a href="/">
        <span class="brand-mark rock-fixed"><img src="/brand-mark.png" alt="Home" /></span>
      </a>
      <span class="theme-switch">
        <button data-theme-button="light" aria-pressed="false">light</button>
        <button data-theme-button="system" aria-pressed="true">system</button>
        <button data-theme-button="dark" aria-pressed="false">dark</button>
      </span>
    </div>

    <!--
      ============================================================
      Scene 1 — COVER (intro hero)
      Lab image is sticky and visible first. Title slab is in flow
      *after* the image, so it starts below the fold and rises up
      to cover. Ends with title fully on screen.
      ============================================================
    -->
    <section class="scene cover">
      <div class="scene-image" style={`background-image: url(${img.lab})`}></div>
      <div class="text-slab title">
        <p class="meta">/projects/danger-lab · 01 of 25</p>
        <h1>Danger<br />Lab</h1>
      </div>
    </section>

    <!--
      ============================================================
      Scene 2 — REVEAL (premise → static CAD image)
      CAD image is sticky-pinned at viewport top from scene start.
      Slab is pulled ON TOP of it via margin-top: -100vh. At scroll-0
      you see the slab covering the static CAD image. As you scroll,
      the slab departs upward, exposing the CAD image that was
      always there. Image dwells via the .dwell spacer.
      ============================================================
    -->
    <section class="scene reveal">
      <div class="scene-image" style={`background-image: url(${img.cad})`}></div>
      <div class="text-slab">
        <p class="label">// premise</p>
        <p class="display">
          How much of your debug time has been spent on a <em>loose wire</em>?
        </p>
      </div>
      <div class="dwell"></div>
    </section>

    <!--
      ============================================================
      Scene 3 — COVER
      Hero render visible first, spec slab covers it from below.
      ============================================================
    -->
    <section class="scene cover">
      <div class="scene-image" style={`background-image: url(${img.hero})`}></div>
      <div class="text-slab">
        <p class="label">// the spec</p>
        <p class="display">
          <code>6 mm × 30.5 cm × 30.5 cm.</code><br />Five 4 mm holes.
        </p>
      </div>
    </section>

    <!--
      ============================================================
      Scene 4 — REVEAL
      Material slab on top of static detail image. Slab departs,
      detail revealed.
      ============================================================
    -->
    <section class="scene reveal">
      <div class="scene-image" style={`background-image: url(${img.detail})`}></div>
      <div class="text-slab">
        <p class="label">// material</p>
        <p class="display">
          PVC. Rigid, workable, <em>doesn't conduct</em>.
        </p>
      </div>
      <div class="dwell"></div>
    </section>

    <!--
      Plain full-bleed image — clean cut, no slab interaction.
    -->
    <img class="bleed" src={img.prusa} alt="Prusa Connect web shortcut on iOS" />

    <nav class="prevnext" aria-label="Adjacent projects">
      <a href="#">
        <span class="label">← prev</span>
        Stacking Stones
      </a>
      <a href="#">
        <span class="label">next →</span>
        Dragon Head
      </a>
    </nav>

    <footer class="footer">
      <span>// I like to make things.</span>
      <span class="icons">
        <span>github</span>
        <span>linkedin</span>
      </span>
    </footer>

    <aside class="notes">
      <p class="label">[layout · 02 · slabs reveal]</p>
      <h3>Two patterns, one primitive (sticky image)</h3>
      <ul>
        <li>
          <span class="pattern-tag">cover</span>
          <strong>Image first, slab arrives.</strong> Sticky image visible at scene start. Slab is in
          flow <em>after</em> the image (so initially below the fold). As you scroll, the slab rises up
          from below to cover the image. Ends with slab covering.
        </li>
        <li>
          <span class="pattern-tag">reveal</span>
          <strong>Slab on top, image static behind.</strong> Sticky image is pinned at viewport top from
          scene start. Slab is pulled ON TOP of the image via
          <code>margin-top: -100vh</code>. At scroll-0 you see the slab covering the static image —
          the image is <em>not</em> below the fold, it's pinned underneath the slab. As you scroll, the
          slab departs upward and the image (which was already there) is revealed. Image then dwells via
          a 200vh <code>.dwell</code> spacer.
        </li>
      </ul>
      <h3>What's static about REVEAL</h3>
      <ul>
        <li>
          The image does not scroll in from below. It is sticky-pinned at viewport top from scene
          start onward — visually it just sits there. The slab is the only thing that moves; the
          image is exposed by the slab leaving.
        </li>
        <li>
          The image stays pinned for the dwell window after the slab passes (~100vh of pure image
          after slab clears, then the scene ends and the image scrolls up with the page). For longer
          dwell, increase <code>.dwell</code> height.
        </li>
      </ul>
      <h3>The mechanism in one block</h3>
      <ul>
        <li>
          <strong>COVER</strong> structure: <code>&lt;image sticky&gt;&lt;slab&gt;</code>. Slab
          starts at scene 100vh (after image), rises into viewport. Scene height: 200vh.
        </li>
        <li>
          <strong>REVEAL</strong> structure:
          <code>&lt;image sticky&gt;&lt;slab margin-top:-100vh&gt;&lt;dwell&gt;</code>. Slab pulled
          to scene 0 (over image). Scene height: 100vh image + 0 net slab + 200vh dwell = 300vh.
          Sticky image active 0–200vh. Slab off-top by 100vh. Dwell visible 100–200vh.
        </li>
      </ul>
      <h3>What's deliberately not used</h3>
      <ul>
        <li>No translucent slabs. Solid only.</li>
        <li>No scroll-snap.</li>
        <li>No JS. Pure CSS with <code>position: sticky</code> and z-index.</li>
        <li>
          No scrolling-image entrance. Images either stay sticky from scene start (cover, reveal) or
          appear as bare full-bleed `&lt;img&gt;` between scenes.
        </li>
      </ul>
    </aside>

    <script>
      const root = document.documentElement;
      const buttons = document.querySelectorAll<HTMLButtonElement>('[data-theme-button]');
      const stored = localStorage.getItem('theme-32bits');
      const apply = (mode: string) => {
        if (mode === 'light' || mode === 'dark') root.dataset.theme = mode;
        else root.removeAttribute('data-theme');
        buttons.forEach((b) =>
          b.setAttribute('aria-pressed', String(b.dataset.themeButton === mode)),
        );
        localStorage.setItem('theme-32bits', mode);
      };
      apply(stored ?? 'system');
      buttons.forEach((b) => b.addEventListener('click', () => apply(b.dataset.themeButton!)));
    </script>
  </body>
</html>
