---
/**
 * Design language proposals — Layout variants (narrowed).
 *
 * Type and palette locked (Engineering + Amber). Slabs and Smear are
 * both green-lit as production layouts; this page now mostly exists to
 * iterate on a sticky-image variant of Slabs.
 */
import '@fontsource-variable/space-grotesk';
import '@fontsource/ibm-plex-sans/400.css';
import '@fontsource/ibm-plex-sans/500.css';
import '@fontsource/ibm-plex-sans/600.css';
import '@fontsource-variable/jetbrains-mono';
import '@styles/design-system.css';

const variants = [
  {
    num: '01',
    name: 'Slabs',
    sub: 'Each section is one viewport',
    blurb:
      'Image slabs, text slabs, and split slabs — every section is exactly 100vh with proximity scroll-snap. Cinematic and deliberate. Picked.',
    feel: 'deck-like / cropped to fit / one thought per screen',
    status: 'picked',
  },
  {
    num: '02',
    name: 'Slabs Reveal',
    sub: 'Variant: sticky images + scrolling text',
    blurb:
      'Same slab geometry as 01, but each "scene" pins its image while text slabs scroll over it. Pure CSS via position: sticky. Iteration in progress.',
    feel: 'pinned imagery / text scrolls past / pure CSS',
    status: 'iterating',
  },
  {
    num: '03',
    name: 'Smear',
    sub: 'Asymmetric editorial breakouts',
    blurb:
      'Mix of full-bleed images, 60/38 splits, hero images that bleed off the right edge, and text-only display sections. Picked for projects that need an editorial voice.',
    feel: 'editorial / asymmetric / display type as voice',
    status: 'picked',
  },
];
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Layout variants · 32bits.io</title>
    <meta name="robots" content="noindex" />
    <style>
      main {
        max-width: 760px;
        margin: 0 auto;
        padding: 5rem 2rem 8rem;
      }
      h1 {
        font-family: var(--font-display);
        font-size: clamp(2rem, 5vw, 3rem);
        font-weight: 600;
        letter-spacing: -0.04em;
        margin: 0 0 0.5rem;
      }
      .lede {
        color: var(--muted);
        font-size: 1.0625rem;
        line-height: 1.55;
        margin: 0 0 0.5rem;
      }
      .preface {
        font-family: var(--font-mono);
        font-size: 0.8125rem;
        color: var(--muted);
        margin: 0 0 3rem;
      }
      .options {
        display: grid;
        gap: 1.25rem;
        list-style: none;
        padding: 0;
        margin: 0;
      }
      .option {
        display: block;
        padding: 1.5rem 1.75rem;
        border: 1px solid var(--rule);
        border-radius: 4px;
        text-decoration: none;
        color: inherit;
        transition:
          border-color 120ms ease,
          transform 120ms ease;
        position: relative;
      }
      .option:hover {
        border-color: var(--accent);
        transform: translateY(-1px);
      }
      .status-pill {
        position: absolute;
        top: 1.5rem;
        right: 1.75rem;
        font-family: var(--font-mono);
        font-size: 0.6875rem;
        text-transform: uppercase;
        letter-spacing: 0.04em;
        color: var(--muted);
        padding: 0.1875rem 0.5rem;
        border: 1px solid var(--rule);
        border-radius: 999px;
      }
      .status-pill.picked {
        color: var(--accent);
        border-color: var(--accent);
      }
      .option-num {
        font-family: var(--font-mono);
        font-size: 0.75rem;
        color: var(--muted);
      }
      .option-name {
        font-family: var(--font-display);
        font-size: 1.5rem;
        font-weight: 600;
        letter-spacing: -0.025em;
        margin: 0.125rem 0 0.25rem;
      }
      .option-sub {
        font-family: var(--font-mono);
        font-size: 0.75rem;
        color: var(--muted);
        margin: 0 0 0.75rem;
      }
      .option-blurb {
        color: var(--fg);
        font-size: 0.9375rem;
        line-height: 1.55;
        margin: 0 0 0.75rem;
      }
      .option-feel {
        font-family: var(--font-mono);
        font-size: 0.75rem;
        color: var(--accent);
        margin: 0;
      }
      .meta {
        margin-top: 4rem;
        padding-top: 2rem;
        border-top: 1px solid var(--rule);
        font-family: var(--font-mono);
        font-size: 0.8125rem;
        color: var(--muted);
        line-height: 1.7;
      }
      .meta strong {
        color: var(--fg);
        font-weight: 500;
      }
      .meta p {
        margin: 0 0 1rem;
      }
      .meta code {
        color: var(--accent);
      }
    </style>
  </head>
  <body>
    <main>
      <h1>Layout variants</h1>
      <p class="lede">
        Slabs and Smear are both shipping. Slabs Reveal is a sticky-image refinement under
        evaluation.
      </p>
      <p class="preface">
        // type: Space Grotesk · IBM Plex Sans · JetBrains Mono · palette: Amber (locked)
      </p>

      <ol class="options">
        {
          variants.map((v) => (
            <li>
              <a href={`/design/option-${v.num.replace(/^0/, '')}`} class="option">
                <span class={`status-pill ${v.status}`}>{v.status}</span>
                <span class="option-num">option_{v.num}</span>
                <h2 class="option-name">{v.name}</h2>
                <p class="option-sub">// {v.sub}</p>
                <p class="option-blurb">{v.blurb}</p>
                <p class="option-feel">// {v.feel}</p>
              </a>
            </li>
          ))
        }
      </ol>

      <div class="meta">
        <p>
          <strong>// production plan:</strong> projects pick their layout via frontmatter
          <code>layout: slabs | smear</code> (or <code>slabs-reveal</code> if 02 lands as a distinct option).
          Different projects can use different layouts based on what suits their content best.
        </p>
        <p>
          <strong>// shared across all variants:</strong> no centered content rails, full-bleed imagery,
          no borders / frames around images, floating brand mark (<code
            >mix-blend-mode: difference</code
          >), mono captions, prev/next terminate-no-wrap, footer band at the very end.
        </p>
        <p>
          <strong>// iteration target:</strong> 02 explores whether the "image stays, text scrolls past,
          next image takes over" feeling — a common Apple-product-page move — is worth the extra DOM/CSS
          complexity over plain Slabs.
        </p>
      </div>
    </main>
  </body>
</html>
